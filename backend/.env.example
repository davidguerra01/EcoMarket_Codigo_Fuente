# EcoMarket Backend — Variables de entorno
# Copia este archivo como .env

# ── Opción A: Docker Compose (recomendado) ────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=12345
DB_NAME=ecomarket_db

# ── Opción B: PostgreSQL en la nube (Neon / Supabase) ────────────────────────
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera un secreto seguro: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
