# EcoMarket Mobile — Variables de entorno
# Copia este archivo como .env y ajusta la URL según tu entorno

# ── Opción 1: Backend en tu PC, celular real en la misma red WiFi ──────────────
EXPO_PUBLIC_API_URL=http://TU_IP_LOCAL:8000

# ── Opción 2: Emulador Android ────────────────────────────────────────────────
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# ── Opción 3: Simulador iOS ───────────────────────────────────────────────────
# EXPO_PUBLIC_API_URL=http://localhost:8000

# ── Opción 4: Backend desplegado en la nube ───────────────────────────────────
# EXPO_PUBLIC_API_URL=https://tu-backend.railway.app
